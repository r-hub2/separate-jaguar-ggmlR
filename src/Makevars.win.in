CXX_STD = CXX17

# Enable C99 format specifiers (%zu, %zd) on MinGW
# Without this, gcc on Windows warns about unknown format character 'z'
PKG_CPPFLAGS_WIN = -D__USE_MINGW_ANSI_STDIO=1

# Vulkan flags (set by configure.win --with-vulkan)
VULKAN_CPPFLAGS = @VULKAN_CPPFLAGS@
VULKAN_LIBS = @VULKAN_LIBS@

# Base include paths and defines
GGML_CPPFLAGS = -I. -Iggml-cpu -Iggml-cpu/arch/x86 \
  -DGGML_VERSION='"0.9.5"' -DGGML_COMMIT='"ggmlR"' \
  -DGGML_USE_CPU $(PKG_CPPFLAGS_WIN)

# --- OpenMP configuration (Windows) ---
#
# On Rtools, gcc and g++ are from the same MinGW toolchain, so
# SHLIB_OPENMP_CFLAGS == SHLIB_OPENMP_CXXFLAGS (both are -fopenmp).
#
# CRAN R CMD check requires strict pairing:
#   - Each SHLIB_OPENMP_* in PKG_C(XX)FLAGS must have a match in PKG_LIBS
#   - PKG_LIBS macro must match the linker language (C++ for this package)
#
# Therefore we use SHLIB_OPENMP_CXXFLAGS for C++ and linker:
#   - PKG_CXXFLAGS = $(SHLIB_OPENMP_CXXFLAGS) -- C++ compilation + linker match
#   - PKG_LIBS     = $(SHLIB_OPENMP_CXXFLAGS) -- linker (C++)
#
# C code needs -fopenmp too: the CPU graph executor's "#pragma omp parallel"
# lives in ggml-cpu-backend.c (a C file). Without -fopenmp on the C compile,
# that pragma is silently ignored and the whole CPU executor runs on ONE thread
# (observed: an LLM text encoder taking ~10 min on a strong CPU). We can't put
# the SHLIB_OPENMP_CXXFLAGS macro in PKG_CFLAGS (R CMD check forbids the wrong
# macro in CFLAGS), so configure.win resolves it to the literal -fopenmp and
# feeds it via @OPENMP_CFLAGS@ (see PKG_CFLAGS below).
#
# The -DGGML_USE_OPENMP define is resolved by configure.win (@OPENMP_CPPFLAGS@:
# either -DGGML_USE_OPENMP or empty). It is NOT gated on $(SHLIB_OPENMP_CXXFLAGS)
# anymore: that make variable can be overridden to empty by the build
# environment, which silently dropped the define and left the CPU backend
# single-threaded (OPENMP=0). Driving it from the Makeconf-derived configure
# value makes OpenMP immune to the environment.
OPENMP_CPPFLAGS = @OPENMP_CPPFLAGS@
GGML_CPPFLAGS += $(OPENMP_CPPFLAGS)

# Force include R compatibility header for CRAN compliance
# This redirects stdout/stderr/abort to R-safe alternatives
# r_ggml_io.c is compiled separately without this header (see rule below)
PKG_CPPFLAGS = $(GGML_CPPFLAGS) $(VULKAN_CPPFLAGS) -DGGML_R_PACKAGE -include r_ggml_compat.h

# CPU SIMD flags (set by configure.win: individual -msse4.2 -mavx2 etc. or empty)
SIMD_CFLAGS = @SIMD_CFLAGS@

# OpenMP flag for C code, resolved to its literal value (-fopenmp) by
# configure.win so the C graph executor is actually multi-threaded. Empty if
# OpenMP is unavailable. See the OpenMP note above.
OPENMP_CFLAGS = @OPENMP_CFLAGS@
# OpenMP flag for C++ compilation and linking, resolved to its literal value
# (-fopenmp) by configure.win. Replaces $(SHLIB_OPENMP_CXXFLAGS) so the build
# environment cannot blank it out. R CMD check's strict OpenMP-macro pairing
# only inspects macro NAMES, so emitting the literal here keeps the check happy
# while guaranteeing the flag is present (same approach as OPENMP_CFLAGS and the
# SIMD flags).
OPENMP_CXXFLAGS = @OPENMP_CXXFLAGS@

PKG_CFLAGS = $(SIMD_CFLAGS) $(OPENMP_CFLAGS)
PKG_CXXFLAGS = $(OPENMP_CXXFLAGS) $(SIMD_CFLAGS)
# -lpthread (= winpthreads on MinGW): the Vulkan backend uses std::thread/
# std::async/std::mutex/std::condition_variable/std::atomic (device, shaders,
# graph). On Linux these are linked via -lpthread explicitly; on Windows they
# were only pulled in transitively. With -static-libstdc++/-static-libgcc that
# transitive path changes, so winpthreads MUST be linked explicitly or the
# threading runtime can diverge -> nondeterministic corruption (~50/50 crash in
# ggml_backend_buffer_init). Match the Linux Makevars.in which already links it.
#
# -static-libstdc++ -static-libgcc: give this module ONE consistent C++ runtime
# (Rtools/MinGW) instead of relying on a shared libstdc++-6.dll that could differ
# between modules. sd2R must do the same.
PKG_LIBS = $(OPENMP_CXXFLAGS) $(VULKAN_LIBS) -lpthread -static-libstdc++ -static-libgcc

# GGML library objects (for static library export)
GGML_OBJECTS = \
  r_ggml_io.o \
  ggml-private.o \
  ggml-alloc.o \
  ggml-quants-legacy.o ggml-quants-iq.o ggml-quants-validate.o ggml-quants-new.o \
  ggml-opt.o gguf.o \
  ggml-backend.o ggml-backend-reg.o ggml-backend-meta.o ggml-threading.o \
  ggml-cpu/traits.o \
  ggml-cpu/ggml-cpu-backend.o ggml-cpu/ggml-cpu.o \
  ggml-cpu/ops-private.o ggml-cpu/vec.o \
  ggml-cpu/binary-ops.o ggml-cpu/unary-ops.o ggml-cpu/repack.o \
  ggml-cpu/quants.o ggml-cpu/hbm.o \
  ggml-cpu/arch/x86/cpu-feats.o ggml-cpu/arch/x86/quants.o ggml-cpu/arch/x86/repack.o

# ONNX loader objects
ONNX_OBJECTS = \
  onnx/onnx_loader.o onnx/onnx_ggml.o \
  onnx/onnx_ops_basic.o onnx/onnx_ops_tensor.o onnx/onnx_ops_nn.o \
  onnx/onnx_ops_quant.o onnx/onnx_ops_special.o \
  onnx/r_onnx.o onnx/rel_pos_bias.o onnx/roi_align.o onnx/nms.o

# R interface objects
R_INTERFACE_OBJECTS = \
  r_interface.o r_interface_graph.o r_interface_vulkan.o r_interface_scheduler.o \
  r_interface_opt.o r_interface_backend.o r_interface_quants.o r_interface_gguf.o

# Vulkan objects (set by configure.win --with-vulkan)
VULKAN_OBJECTS = @VULKAN_OBJECTS@
GGML_OBJECTS += $(VULKAN_OBJECTS)

# All objects for shared library
OBJECTS = $(R_INTERFACE_OBJECTS) $(GGML_OBJECTS) $(ONNX_OBJECTS)

# Static library for linking by other packages
STATICLIB = libggml.a

$(SHLIB): $(OBJECTS) staticlib

.PHONY: staticlib

staticlib: $(GGML_OBJECTS)
	mkdir -p ../inst/lib
	rm -f ../inst/lib/$(STATICLIB)
	$(AR) rcs ../inst/lib/$(STATICLIB) $(GGML_OBJECTS)
	strip --strip-debug ../inst/lib/$(STATICLIB) 2>/dev/null || true

# R interface files and r_ggml_io.c include R headers (R.h, Rinternals.h)
# which contain __attribute__((format(printf, ...))). Our macro
# '#define printf r_ggml_printf' would turn this into format(r_ggml_printf, ...)
# which GCC rejects as an unrecognized format type.
# R_GGML_IO_IMPL disables all macro redirections in r_ggml_compat.h.
# These files use only R API (Rprintf, Rf_error), not stdio printf/fprintf,
# so they don't need the redirections.
r_ggml_io.o: PKG_CPPFLAGS += -DR_GGML_IO_IMPL
r_interface.o: PKG_CPPFLAGS += -DR_GGML_IO_IMPL
r_interface_graph.o: PKG_CPPFLAGS += -DR_GGML_IO_IMPL
r_interface_vulkan.o: PKG_CPPFLAGS += -DR_GGML_IO_IMPL
r_interface_scheduler.o: PKG_CPPFLAGS += -DR_GGML_IO_IMPL
r_interface_opt.o: PKG_CPPFLAGS += -DR_GGML_IO_IMPL
r_interface_backend.o: PKG_CPPFLAGS += -DR_GGML_IO_IMPL
r_interface_quants.o: PKG_CPPFLAGS += -DR_GGML_IO_IMPL
# ONNX files: r_onnx.c includes R headers
r_interface_gguf.o: PKG_CPPFLAGS += -DR_GGML_IO_IMPL
onnx/r_onnx.o: PKG_CPPFLAGS += -DR_GGML_IO_IMPL
