#!/bin/sh

# Configure script for ggmlR (Windows/Rtools)
# Optional Vulkan GPU backend and SIMD acceleration,
# then generates Makevars.win from Makevars.win.in

# Default values
USE_VULKAN="auto"
USE_SIMD="no"
VULKAN_CPPFLAGS=""
VULKAN_LIBS=""
VULKAN_OBJECTS=""

# Parse arguments.
#
# IMPORTANT (Windows): R *ignores* --configure-args / configure.args on
# Windows -- they are only honoured by the Unix ./configure path. So "$@" is
# always empty here regardless of how the user calls install.packages() or
# remotes::install_github(configure.args=...). Confirmed by diagnostics: $@,
# R_CONFIGURE_ARGS, CONFIGURE_ARGS all come through empty.
#
# The only reliable channel on Windows is environment variables set BEFORE the
# install. We therefore honour:
#   Sys.setenv(GGML_USE_SIMD = "1")      -> enable SIMD
#   Sys.setenv(GGML_USE_VULKAN = "0")    -> force-disable Vulkan
# These also work on Unix, where "$@" additionally carries --with-simd etc.
for arg in "$@"; do
  case "$arg" in
    --with-vulkan)
      USE_VULKAN="yes"
      ;;
    --without-vulkan)
      USE_VULKAN="no"
      ;;
    --with-simd)
      USE_SIMD="yes"
      ;;
  esac
done

# Environment-variable overrides (primary channel on Windows).
case "$GGML_USE_SIMD" in
  1|yes|YES|true|TRUE|on|ON)
    USE_SIMD="yes"
    ;;
esac
case "$GGML_USE_VULKAN" in
  1|yes|YES|true|TRUE|on|ON)
    USE_VULKAN="yes"
    ;;
  0|no|NO|false|FALSE|off|OFF)
    USE_VULKAN="no"
    ;;
esac

# --- Vulkan detection ---
#
# Three modes:
#   --with-vulkan    : require Vulkan, error if deps missing
#   --without-vulkan : disable Vulkan unconditionally
#   (default) auto   : enable if Vulkan SDK and glslc are found
#

if [ "$USE_VULKAN" = "no" ]; then
  echo "Vulkan: disabled by --without-vulkan"
fi

if [ "$USE_VULKAN" = "auto" ] || [ "$USE_VULKAN" = "yes" ]; then
  echo "Checking for Vulkan support..."

  # Check for glslc (shader compiler)
  GLSLC=""
  if [ -n "$VULKAN_SDK" ] && [ -x "$VULKAN_SDK/Bin/glslc.exe" ]; then
    GLSLC="$VULKAN_SDK/Bin/glslc.exe"
  else
    GLSLC=$(command -v glslc 2>/dev/null || command -v glslc.exe 2>/dev/null)
  fi

  # Check for Vulkan headers via VULKAN_SDK
  HAVE_VULKAN_H="no"
  if [ -n "$VULKAN_SDK" ] && [ -d "$VULKAN_SDK/Include" ]; then
    HAVE_VULKAN_H="yes"
  fi

  if [ -z "$GLSLC" ] || [ "$HAVE_VULKAN_H" = "no" ]; then
    if [ "$USE_VULKAN" = "yes" ]; then
      echo "ERROR: Vulkan dependencies not found."
      echo "  Install Vulkan SDK from: https://vulkan.lunarg.com/sdk/home"
      echo "  Ensure VULKAN_SDK environment variable is set."
      [ -z "$GLSLC" ] && echo "  Missing: glslc.exe (shader compiler)"
      [ "$HAVE_VULKAN_H" = "no" ] && echo "  Missing: Vulkan headers (VULKAN_SDK/Include)"
      exit 1
    else
      echo ""
      echo "Note: Vulkan GPU support not enabled (Vulkan SDK not found)."
      echo "  To enable Vulkan acceleration, install:"
      echo "    Vulkan SDK: https://vulkan.lunarg.com/sdk/home"
      echo "  Ensure VULKAN_SDK environment variable is set."
      echo "  Building CPU-only version."
      echo ""
      USE_VULKAN="no"
    fi
  else
    USE_VULKAN="yes"
    echo "Vulkan SDK detected: $VULKAN_SDK"
    echo "Found glslc: $GLSLC"
  fi
fi

# --- OpenMP flags ---
#
# The ggml CPU graph executor parallelizes via "#pragma omp parallel" in
# ggml-cpu-backend.c (a C file). That pragma is a no-op unless the file is
# compiled with -fopenmp. Makevars.win passes the OpenMP flag to C++ only
# (PKG_CXXFLAGS), so the C executor stayed single-threaded on Windows even with
# -DGGML_USE_OPENMP defined — text-heavy CPU work (e.g. an LLM text encoder)
# ran on one core and could take minutes.
#
# We resolve SHLIB_OPENMP_CXXFLAGS from R's Makeconf to its literal value
# (-fopenmp on Rtools) here, so PKG_CFLAGS in Makevars.win carries the literal
# flag rather than the SHLIB_OPENMP_* macro name. R CMD check's strict macro
# pairing only inspects the macro names, so emitting the literal keeps the C
# code multi-threaded without tripping the check (same approach as the Linux
# configure and the SIMD flags below). The linker pairing is already satisfied
# by PKG_LIBS = $(SHLIB_OPENMP_CXXFLAGS) ... (this is a C++-linked package).
OPENMP_CFLAGS=""
# R on Windows keeps Makeconf under an arch subdir (etc/x64/Makeconf), not
# etc/Makeconf. Probe the arch-specific location first, then $R_ARCH, then the
# plain path, so OpenMP is detected on Rtools (otherwise the CPU graph executor
# stays single-threaded).
MAKECONF=""
for cand in \
    "${R_HOME}/etc/x64/Makeconf" \
    "${R_HOME}/etc${R_ARCH}/Makeconf" \
    "${R_HOME}/etc/Makeconf"; do
  if [ -f "$cand" ]; then
    MAKECONF="$cand"
    break
  fi
done
if [ -n "$MAKECONF" ]; then
  OPENMP_CFLAGS=$(grep '^SHLIB_OPENMP_CXXFLAGS' "$MAKECONF" | sed 's/[^=]*= *//')
fi
# Guard against unexpected non-flag content (must start with '-'). On some
# setups SHLIB_OPENMP_CXXFLAGS can arrive empty from the environment; here we
# read it straight from Makeconf instead, so an empty environment variable can
# no longer silently disable OpenMP.
case "$OPENMP_CFLAGS" in
  -*) ;;
  *) OPENMP_CFLAGS="" ;;
esac

# Resolve the OpenMP define here too, decoupled from the make variable
# $(SHLIB_OPENMP_CXXFLAGS). Makevars.win previously gated -DGGML_USE_OPENMP on
# "ifneq ($(SHLIB_OPENMP_CXXFLAGS),)"; that variable can be overridden (to
# empty) by the build environment, which silently dropped the define and left
# the CPU backend single-threaded (OPENMP=0 in sd_get_system_info). Driving the
# define from this Makeconf-derived value makes OpenMP immune to the
# environment. OPENMP_CXXFLAGS carries the literal -fopenmp for C++ compilation
# and linking (same value; gcc/g++ share the MinGW toolchain on Rtools).
OPENMP_CPPFLAGS=""
OPENMP_CXXFLAGS=""
if [ -n "$OPENMP_CFLAGS" ]; then
  OPENMP_CPPFLAGS="-DGGML_USE_OPENMP"
  OPENMP_CXXFLAGS="$OPENMP_CFLAGS"
  echo "OpenMP: enabled for C (${OPENMP_CFLAGS})"
else
  echo "OpenMP: not available for C (CPU graph executor will be single-threaded)"
fi

# --- CPU SIMD flags ---
#
# CRAN policy forbids non-portable compilation flags like -mavx2, -msse4.2 etc.
# SIMD is disabled by default. Users who want SIMD acceleration can enable it with:
#   install.packages("ggmlR", configure.args = "--with-simd")
#
SIMD_CFLAGS=""
if [ "$USE_SIMD" = "yes" ]; then
  echo "SIMD: enabled by --with-simd, detecting supported flags..."
  CC_CMD="${CC:-gcc}"

  # Use real temp files rather than stdin + "-o /dev/null". On Rtools/MinGW,
  # gcc cannot write an executable to the /dev/null special device and the
  # "-x c -" stdin path is also unreliable, so every probe failed silently and
  # SIMD fell back to scalar even when the flags are supported.
  SIMD_TEST_C="$(mktemp 2>/dev/null || echo simd_test_$$).c"
  SIMD_TEST_OUT="${SIMD_TEST_C}.out"
  printf 'int main(){return 0;}\n' > "$SIMD_TEST_C"

  check_cflag() {
    if $CC_CMD $1 -o "$SIMD_TEST_OUT" "$SIMD_TEST_C" 2>/dev/null; then
      SIMD_CFLAGS="$SIMD_CFLAGS $1"
      echo "  Found: $1"
      rm -f "$SIMD_TEST_OUT"
      return 0
    fi
    return 1
  }

  SIMD_ARCH=$(uname -m 2>/dev/null || echo "unknown")
  case "$SIMD_ARCH" in
    x86_64|i386|i686|amd64)
      check_cflag -msse3
      check_cflag -mssse3
      check_cflag -msse4.1
      check_cflag -msse4.2
      check_cflag -mavx
      check_cflag -mavx2
      check_cflag -mfma
      check_cflag -mf16c
      ;;
    *)
      echo "  Non-x86 architecture ($SIMD_ARCH), skipping x86 SIMD flags"
      ;;
  esac

  rm -f "$SIMD_TEST_C" "$SIMD_TEST_OUT"

  if [ -z "$SIMD_CFLAGS" ]; then
    echo "  No SIMD flags detected, using scalar fallback"
  fi
else
  echo "SIMD: disabled (default). Use --with-simd to enable."
fi

# --- Build Vulkan shaders ---
if [ "$USE_VULKAN" = "yes" ]; then

  # Normalize the SDK path: convert Windows backslashes to forward slashes.
  # gcc/MinGW accept forward slashes, and this keeps the path safe for use in
  # the right-hand side of the sed substitutions below. Native backslashes
  # (e.g. C:\VulkanSDK\1.4.350.0) would be misread by sed as backreferences
  # (\1, \4, ...) -> "invalid reference \1 on 's' command's RHS".
  VULKAN_SDK_FWD=$(printf '%s' "$VULKAN_SDK" | tr '\\' '/')

  # Set Vulkan include and lib paths from SDK
  VULKAN_CPPFLAGS="-I\"${VULKAN_SDK_FWD}/Include\""
  VULKAN_LIBS="-L\"${VULKAN_SDK_FWD}/Lib\" -lvulkan-1"

  echo "Vulkan CPPFLAGS: $VULKAN_CPPFLAGS"
  echo "Vulkan LIBS: $VULKAN_LIBS"

  # Build shader generator
  echo "Building shader generator..."
  cd src/ggml-vulkan/vulkan-shaders

  # Detect glslc feature support via test shaders. These -D defines gate the
  # #if blocks in vulkan-shaders-gen.cpp that emit the coopmat / coopmat2 /
  # integer_dot / bf16 shader variants. Without them the generator silently
  # skips those shaders and the Vulkan backend falls back at runtime
  # (e.g. RDNA4 mmq subgroup pipelines depend on INTEGER_DOT support).
  SHADERGEN_DEFINES=""
  if [ -f "feature-tests/coopmat.comp" ]; then
    if "$GLSLC" --target-env=vulkan1.2 -o /dev/null feature-tests/coopmat.comp 2>/dev/null; then
      echo "  coopmat (GL_KHR_cooperative_matrix): supported"
      SHADERGEN_DEFINES="$SHADERGEN_DEFINES -DGGML_VULKAN_COOPMAT_GLSLC_SUPPORT"
    else
      echo "  coopmat (GL_KHR_cooperative_matrix): not supported"
    fi
  fi
  if [ -f "feature-tests/coopmat2.comp" ]; then
    if "$GLSLC" --target-env=vulkan1.2 -o /dev/null feature-tests/coopmat2.comp 2>/dev/null; then
      echo "  coopmat2 (GL_NV_cooperative_matrix2): supported"
      SHADERGEN_DEFINES="$SHADERGEN_DEFINES -DGGML_VULKAN_COOPMAT2_GLSLC_SUPPORT"
    else
      echo "  coopmat2 (GL_NV_cooperative_matrix2): not supported"
    fi
  fi
  if [ -f "feature-tests/integer_dot.comp" ]; then
    if "$GLSLC" --target-env=vulkan1.2 -o /dev/null feature-tests/integer_dot.comp 2>/dev/null; then
      echo "  integer_dot (GL_EXT_integer_dot_product): supported"
      SHADERGEN_DEFINES="$SHADERGEN_DEFINES -DGGML_VULKAN_INTEGER_DOT_GLSLC_SUPPORT"
    else
      echo "  integer_dot (GL_EXT_integer_dot_product): not supported"
    fi
  fi
  if [ -f "feature-tests/bfloat16.comp" ]; then
    if "$GLSLC" --target-env=vulkan1.2 -o /dev/null feature-tests/bfloat16.comp 2>/dev/null; then
      echo "  bfloat16 (GL_EXT_bfloat16): supported"
      SHADERGEN_DEFINES="$SHADERGEN_DEFINES -DGGML_VULKAN_BFLOAT16_GLSLC_SUPPORT"
    else
      echo "  bfloat16 (GL_EXT_bfloat16): not supported"
    fi
  fi

  CXX="${CXX:-g++}"
  $CXX -std=c++17 -O2 $SHADERGEN_DEFINES -o vulkan-shaders-gen.exe vulkan-shaders-gen.cpp
  if [ $? -ne 0 ]; then
    echo "ERROR: Failed to build vulkan-shaders-gen"
    exit 1
  fi

  # Wipe any stale generated/ from a previous configure run (possibly built
  # with a different glslc). The shader set depends on glslc feature support;
  # a partial overwrite would leave orphan .cpp whose symbols are no longer
  # declared in the regenerated header, breaking the final link. Always
  # regenerate the full set so generated/ matches the current glslc exactly.
  rm -rf ../generated
  mkdir -p ../generated/spv

  # Generate header file
  echo "Generating shader header..."
  ./vulkan-shaders-gen.exe \
    --output-dir ../generated/spv \
    --target-hpp ../generated/ggml-vulkan-shaders.hpp

  # Generate shader cpp files
  echo "Compiling shaders (this may take a while)..."
  SHADER_COUNT=0
  SHADER_TOTAL=$(ls -1 *.comp 2>/dev/null | wc -l)

  for shader in *.comp; do
    SHADER_COUNT=$((SHADER_COUNT + 1))
    printf "\r  [%d/%d] %s" "$SHADER_COUNT" "$SHADER_TOTAL" "$shader"
    ./vulkan-shaders-gen.exe \
      --glslc "$GLSLC" \
      --source "$(pwd)/$shader" \
      --output-dir ../generated/spv \
      --target-hpp ../generated/ggml-vulkan-shaders.hpp \
      --target-cpp "../generated/${shader}.cpp"
    if [ $? -ne 0 ]; then
      echo ""
      echo "ERROR: Failed to compile shader: $shader"
      exit 1
    fi
  done
  echo ""
  echo "Generated $SHADER_COUNT shader files"

  cd ../../..

  # Build list of shader object files
  VULKAN_OBJECTS="ggml-vulkan/ggml-vulkan.o"
  for cpp in src/ggml-vulkan/generated/*.cpp; do
    base=$(basename "$cpp" .cpp)
    VULKAN_OBJECTS="$VULKAN_OBJECTS ggml-vulkan/generated/${base}.o"
  done

  VULKAN_CPPFLAGS="$VULKAN_CPPFLAGS -DGGML_USE_VULKAN -Iggml-vulkan -Iggml-vulkan/generated $SHADERGEN_DEFINES"

  echo "Vulkan backend enabled with $SHADER_COUNT shaders"
fi

# Generate Makevars.win from template
echo "Generating src/Makevars.win..."

sed \
  -e "s|@VULKAN_CPPFLAGS@|$VULKAN_CPPFLAGS|g" \
  -e "s|@VULKAN_LIBS@|$VULKAN_LIBS|g" \
  -e "s|@VULKAN_OBJECTS@|$VULKAN_OBJECTS|g" \
  -e "s|@SIMD_CFLAGS@|$SIMD_CFLAGS|g" \
  -e "s|@OPENMP_CFLAGS@|$OPENMP_CFLAGS|g" \
  -e "s|@OPENMP_CXXFLAGS@|$OPENMP_CXXFLAGS|g" \
  -e "s|@OPENMP_CPPFLAGS@|$OPENMP_CPPFLAGS|g" \
  src/Makevars.win.in > src/Makevars.win

# Sync public headers from src/ to inst/include/
echo "Syncing public headers to inst/include/..."
mkdir -p inst/include
for h in ggml.h ggml-alloc.h ggml-backend.h ggml-backend-impl.h ggml-common.h \
          ggml-cpp.h ggml-cpu.h ggml-impl.h ggml-opt.h ggml-quants.h \
          ggml-threading.h ggml-vulkan.h gguf.h r_ggml_compat.h; do
  if [ -f "src/$h" ]; then
    cp "src/$h" "inst/include/$h"
  fi
done

echo "Configuration complete."
if [ "$USE_VULKAN" = "yes" ]; then
  echo "  Vulkan: ENABLED"
else
  echo "  Vulkan: disabled"
fi
if [ "$USE_SIMD" = "yes" ]; then
  echo "  SIMD:   ENABLED ($SIMD_CFLAGS )"
else
  echo "  SIMD:   disabled"
fi
if [ -n "$OPENMP_CFLAGS" ]; then
  echo "  OpenMP: ENABLED ($OPENMP_CFLAGS )"
else
  echo "  OpenMP: disabled (single-threaded CPU)"
fi
